#Api2

# Launcher widget — opens fuzzel app launcher

export button "launcher" {
  style = "module"
  class = "module"
  value = "view-app-grid-symbolic"
  tooltip = "Applications (Alt+A)"
  action = Exec("fuzzel")
}

#CSS

button#launcher {
  padding: 6px 10px;
  border-radius: 8px;
  background-color: transparent;
  color: #cdd6f4;
}

button#launcher:hover {
  background-color: rgba(69, 71, 90, 0.5);
}
