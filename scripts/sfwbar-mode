#!/bin/bash
# -------------------------------------------------------------------
# SFWBar Mode Selector
# Switch between SFWBar modes with validation
# -------------------------------------------------------------------

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
OCWS_DIR="$PROJECT_DIR/dotfiles/ocws"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ocws"
PID_FILE="/tmp/sfwbar.pid"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

pass() { echo -e "${GREEN}✓${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
info() { echo -e "${CYAN}→${NC} $1"; }

# Available modes
declare -A MODES=(
    ["doublepanel"]="Dual-panel mode (top status bar + bottom dock/taskbar)"
    ["crystaldock"]="Single status bar + external crystal-dock"
    ["minimal"]="Minimal status bar (clock, volume, battery, tray)"
)

# ============================================================
# Functions
# ============================================================

show_modes() {
    echo -e "${BOLD}Available Modes:${NC}"
    echo ""
    for mode in "${!MODES[@]}"; do
        echo -e "  ${CYAN}$mode${NC}"
        echo "    ${MODES[$mode]}"
        echo ""
    done
}

validate_mode() {
    local mode="$1"
    local config_file="$OCWS_DIR/modes/${mode}.mode"
    
    if [[ ! -f "$config_file" ]]; then
        fail "Mode config not found: $config_file"
        return 1
    fi
    
    # Run validator on the mode
    info "Validating mode: $mode"
    if "$SCRIPT_DIR/validate-sfwbar.sh" "$OCWS_DIR" 2>/dev/null | grep -q "All configs pass"; then
        pass "Mode validation passed"
        return 0
    else
        warn "Mode validation had warnings (proceeding anyway)"
        return 0
    fi
}

get_current_mode() {
    if [[ -f "$CONFIG_DIR/mode" ]]; then
        cat "$CONFIG_DIR/mode"
    else
        echo "doublepanel"
    fi
}

start_sfwbar() {
    local mode="$1"
    local config_file="$OCWS_DIR/modes/${mode}.mode"
    
    # Kill existing sfwbar
    if pgrep -x sfwbar >/dev/null 2>&1; then
        info "Stopping existing sfwbar..."
        pkill -x sfwbar
        sleep 0.3
    fi
    
    # Copy config to user dir if needed
    mkdir -p "$CONFIG_DIR/modes"
    cp -r "$OCWS_DIR/modes/"* "$CONFIG_DIR/modes/" 2>/dev/null || true
    
    # Start sfwbar with the mode config
    info "Starting sfwbar in $mode mode..."
    info "Config: $config_file"
    
    sfwbar -c "$config_file" &
    echo $! > "$PID_FILE"
    pass "sfwbar started (PID: $!)"
    
    # Save current mode
    mkdir -p "$(dirname "$CONFIG_DIR/mode")"
    echo "$mode" > "$CONFIG_DIR/mode"
    pass "Mode saved: $mode"
}

stop_sfwbar() {
    if pgrep -x sfwbar >/dev/null 2>&1; then
        pkill -x sfwbar
        rm -f "$PID_FILE"
        pass "sfwbar stopped"
    else
        warn "sfwbar not running"
    fi
}

status_sfwbar() {
    local current_mode=$(get_current_mode)
    
    if pgrep -x sfwbar >/dev/null 2>&1; then
        local pid=$(pgrep -x sfwbar)
        pass "sfwbar running (PID: $pid)"
        info "Current mode: $current_mode"
    else
        info "sfwbar not running"
        info "Last mode: $current_mode"
    fi
}

show_help() {
    echo -e "${BOLD}SFWBar Mode Selector${NC}"
    echo ""
    echo "Usage: $(basename "$0") [command] [mode]"
    echo ""
    echo "Commands:"
    echo "  start <mode>   Start sfwbar in specified mode"
    echo "  stop           Stop sfwbar"
    echo "  restart <mode> Restart sfwbar in specified mode"
    echo "  status         Check if sfwbar is running"
    echo "  modes          Show available modes"
    echo "  current        Show current mode"
    echo "  validate       Validate all modes"
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") start doublepanel"
    echo "  $(basename "$0") start crystaldock"
    echo "  $(basename "$0") start minimal"
    echo "  $(basename "$0") stop"
    echo "  $(basename "$0") status"
    echo ""
    show_modes
}

validate_all_modes() {
    echo -e "${BOLD}Validating All Modes:${NC}"
    echo ""
    
    local all_valid=true
    for mode in "${!MODES[@]}"; do
        echo -e "${CYAN}Mode: $mode${NC}"
        if validate_mode "$mode"; then
            pass "  Valid"
        else
            fail "  Invalid"
            all_valid=false
        fi
        echo ""
    done
    
    if $all_valid; then
        echo -e "${GREEN}All modes are valid!${NC}"
    else
        echo -e "${RED}Some modes have issues.${NC}"
    fi
}

# ============================================================
# Main
# ============================================================

case "${1:-help}" in
    start)
        if [[ -z "${2:-}" ]]; then
            fail "Please specify a mode"
            show_modes
            exit 1
        fi
        
        mode="$2"
        if [[ -z "${MODES[$mode]+x}" ]]; then
            fail "Unknown mode: $mode"
            show_modes
            exit 1
        fi
        
        validate_mode "$mode"
        start_sfwbar "$mode"
        ;;
    stop)
        stop_sfwbar
        ;;
    restart)
        if [[ -z "${2:-}" ]]; then
            fail "Please specify a mode"
            show_modes
            exit 1
        fi
        
        mode="$2"
        if [[ -z "${MODES[$mode]+x}" ]]; then
            fail "Unknown mode: $mode"
            show_modes
            exit 1
        fi
        
        stop_sfwbar
        sleep 0.5
        validate_mode "$mode"
        start_sfwbar "$mode"
        ;;
    status)
        status_sfwbar
        ;;
    modes)
        show_modes
        ;;
    current)
        echo "$(get_current_mode)"
        ;;
    validate)
        validate_all_modes
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        warn "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
