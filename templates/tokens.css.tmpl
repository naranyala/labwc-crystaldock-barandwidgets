/* OCWS CSS Tokens — Single Source of Truth for Colors
 * Generated by theme-engine from {{THEME_NAME}} theme profile
 * Do NOT edit manually — run: theme-engine.sh apply themes/<name>.ini
 *
 * All widgets, bars, and popups should use these @define-color tokens
 * instead of hardcoded hex/rgba values.
 * ============================================================ */

/* === Base Colors === */
@define-color ocws_bg {{COLOR_BG}};
@define-color ocws_fg {{COLOR_FG}};
@define-color ocws_mantle {{COLOR_MANTLE}};
@define-color ocws_crust {{COLOR_CRUST}};

/* === Surface Colors === */
@define-color ocws_surface0 {{COLOR_SURFACE0}};
@define-color ocws_surface1 {{COLOR_SURFACE}};
@define-color ocws_surface2 {{COLOR_BORDER}};

/* === Overlay Colors === */
@define-color ocws_overlay0 {{COLOR_OVERLAY0}};
@define-color ocws_overlay1 {{COLOR_OVERLAY1}};
@define-color ocws_overlay2 {{COLOR_OVERLAY2}};

/* === Text Colors === */
@define-color ocws_subtext0 {{COLOR_SUBTEXT0}};
@define-color ocws_subtext1 {{COLOR_SUBTEXT1}};
@define-color ocws_text {{COLOR_FG}};

/* === Accent Colors === */
@define-color ocws_blue {{COLOR_BLUE}};
@define-color ocws_sapphire {{COLOR_SAPPHIRE}};
@define-color ocws_sky {{COLOR_SKY}};
@define-color ocws_teal {{COLOR_TEAL}};
@define-color ocws_green {{COLOR_OK}};
@define-color ocws_yellow {{COLOR_YELLOW}};
@define-color ocws_peach {{COLOR_PEACH}};
@define-color ocws_maroon {{COLOR_MAROON}};
@define-color ocws_red {{COLOR_URGENT}};
@define-color ocws_mauve {{COLOR_MAUVE}};
@define-color ocws_pink {{COLOR_PINK}};
@define-color ocws_flamingo {{COLOR_FLAMINGO}};
@define-color ocws_rosewater {{COLOR_ROSEWATER}};
@define-color ocws_lavender {{COLOR_LAVENDER}};

/* === Semantic Aliases === */
@define-color ocws_accent {{COLOR_ACCENT}};
@define-color ocws_urgent {{COLOR_URGENT}};
@define-color ocws_warning {{COLOR_YELLOW}};
@define-color ocws_ok {{COLOR_OK}};
@define-color ocws_info {{COLOR_SKY}};
@define-color ocws_muted {{COLOR_MUTED}};

/* === Derived / Alpha Variants === */
@define-color ocws_surface0_alpha50 alpha({{COLOR_SURFACE0}}, 0.5);
@define-color ocws_surface1_alpha30 alpha({{COLOR_SURFACE}}, 0.3);
@define-color ocws_surface1_alpha50 alpha({{COLOR_SURFACE}}, 0.5);
@define-color ocws_surface2_alpha30 alpha({{COLOR_BORDER}}, 0.3);
@define-color ocws_bg_alpha85 alpha({{COLOR_BG}}, 0.85);
@define-color ocws_bg_alpha92 alpha({{COLOR_BG}}, 0.92);
@define-color ocws_bg_alpha95 alpha({{COLOR_BG}}, 0.95);
@define-color ocws_fg_alpha30 alpha({{COLOR_FG}}, 0.3);
@define-color ocws_fg_alpha50 alpha({{COLOR_FG}}, 0.5);
@define-color ocws_fg_alpha60 alpha({{COLOR_FG}}, 0.6);
@define-color ocws_accent_alpha15 alpha({{COLOR_ACCENT}}, 0.15);
@define-color ocws_accent_alpha20 alpha({{COLOR_ACCENT}}, 0.2);
@define-color ocws_urgent_alpha15 alpha({{COLOR_URGENT}}, 0.15);
@define-color ocws_urgent_alpha20 alpha({{COLOR_URGENT}}, 0.2);
