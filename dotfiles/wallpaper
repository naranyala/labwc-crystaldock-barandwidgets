#!/usr/bin/env bash
# dotfiles/wallpaper

WALLPAPER_DIR="${HOME}/Pictures/wallpapers"
SOURCES_FILE="$(dirname "$0")/wallpaper-sources.txt"

# --- Internal Functions ---

sync_wallpapers() {
    echo "Syncing wallpapers..."
    mkdir -p "$WALLPAPER_DIR"
    if [[ ! -f "$SOURCES_FILE" ]]; then
        echo "Error: $SOURCES_FILE not found."
        return 1
    fi

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^#.*$ ]] && continue
        [[ -z "$line" ]] && continue
        read -r type value <<< "$line"

        case "$type" in
            git)
                echo "  Syncing repo: $value"
                tmp_dir=$(mktemp -d)
                # Try to clone shallowly. Redirect errors to /dev/null to keep output clean.
                if git clone --depth 1 "$value" "$tmp_dir" 2>/dev/null; then
                    find "$tmp_dir" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) -exec cp -n {} "$WALLPAPER_DIR" \;
                    echo "    Success."
                else
                    echo "    Error: Could not clone (Repo might be private or URL is wrong)."
                fi
                rm -rf "$tmp_dir"
                ;;
            http|https)
                echo "  Downloading: $value"
                filename=$(echo "$value" | awk -F'/' '{print $NF}' | cut -d'?' -f1)
                [[ ! "$filename" =~ \.[a-zA-Z0-9]+$ ]] && filename="${filename}.jpg"
                if [[ ! -f "$WALLPAPER_DIR/$filename" ]]; then
                    curl -sL "$value" -o "$WALLPAPER_DIR/$filename"
                fi
                ;;
        esac
    done < "$SOURCES_FILE"
    echo "Sync complete."
}

set_wallpaper() {
    local img="$1"
    if [[ -z "$img" ]]; then
        img=$(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) | shuf -n 1)
    fi
    [[ -z "$img" || ! -f "$img" ]] && { echo "Error: Invalid wallpaper: $img"; return 1; }
    
    img=$(realpath "$img")
    echo "Setting: $img"

    # 1. GNOME
    if [[ "$XDG_CURRENT_DESKTOP" == "GNOME" ]] || [[ "$XDG_CURRENT_DESKTOP" == *"GNOME"* ]]; then
        gsettings set org.gnome.desktop.background picture-uri "file://$img"
        gsettings set org.gnome.desktop.background picture-uri-dark "file://$img"

    # 2. Hyprland
    elif [[ "$XDG_CURRENT_DESKTOP" == "Hyprland" ]] || command -v hyprctl >/dev/null 2>&1 && hyprctl version >/dev/null 2>&1; then
        hyprctl hyprpaper preload "$img" && hyprctl hyprpaper wallpaper ",$img"

    # 3. Sway
    elif [[ "$XDG_CURRENT_DESKTOP" == "sway" ]] || command -v swaybg >/dev/null 2>&1; then
        pkill swaybg
        swaybg -i "$img" -m fill &

    # 4. swww (Generic Wayland)
    elif command -v swww >/dev/null 2>&1; then
        swww img "$img" --transition-type random

    # 5. feh (X11)
    elif command -v feh >/dev/null 2>&1; then
        feh --bg-fill "$img"

    # 6. nitrogen (X11)
    elif command -v nitrogen >/dev/null 2>&1; then
        nitrogen --set-geometry "$img"

    else
        echo "Error: No supported wallpaper setter found."
        return 1
    fi
}

# --- Main Logic ---

case "$1" in
    sync)
        sync_wallpapers
        ;;
    set)
        set_wallpaper "$2"
        ;;
    daemon)
        interval="${2:-3600}"
        echo "Starting wallpaper daemon (interval: ${interval}s)..."
        while true; do
            set_wallpaper
            sleep "$interval"
        done
        ;;
    *)
        echo "Usage: wallpaper {sync|set [path]|daemon [seconds]}"
        exit 1
        ;;
esac
