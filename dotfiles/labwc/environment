# labwc environment variables — generated by theme-engine
# From: Catppuccin Mocha

# XDG dirs
XDG_CURRENT_DESKTOP=labwc
XDG_SESSION_TYPE=wayland
XDG_SESSION_DESKTOP=labwc

# Qt
QT_QPA_PLATFORM=wayland
QT_WAYLAND_DISABLE_WINDOWDECORATION=1
SDL_VIDEODRIVER=wayland
CLUTTER_BACKEND=wayland
MOZ_ENABLE_WAYLAND=1
ELECTRON_OZONE_PLATFORM_HINT=auto

# GTK Rendering (Wayland preferred, X11 fallback for compatibility)
GDK_BACKEND=wayland,x11
GTK_USE_PORTAL=0

# Cursor
XCURSOR_THEME=Catppuccin-Mocha-Dark
XCURSOR_SIZE=24

# Font Rendering — FreeType interpreter v35 (latest)
FREETYPE_PROPERTIES=truetype:interpreter-version=35



# Qt Theme
QT_QPA_PLATFORMTHEME=qt6ct

# Terminal
TERMINAL=foot

# Sudo GUI Prompt Configuration
# Set rofi-askpass as the default GUI password prompter for sudo -A
# SUDO_ASKPASS=~/.local/bin/fuzzel-askpass
SUDO_ASKPASS=~/.local/bin/rofi-askpass

# Disable GNOME Keyring "login keyring" password popup
# gnome-keyring-daemon auto-starts via D-Bus/systemd and prompts for a
# password on every session. Setting GNOME_KEYRING_CONTROL to empty
# prevents the daemon from binding. SSH_AUTH_SOCK is reset here so our
# dedicated ssh-agent (see autostart) takes over cleanly.
GNOME_KEYRING_CONTROL=
SSH_AUTH_SOCK=
