#Api2
# ocws.config — Common OCWS infrastructure
# NOT launched directly — use *.mode as entry points
# Launch: sfwbar -f dual.mode
# CSS is loaded via -c flag: sfwbar -f <mode> -c ocws-theme.css

Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "36px"

switcher { disable = false }

Function SfwbarInit() {}

# --- Env overrides ---
include("env.config")

# --- Plugin Autoloader ---
include("plugins.config")
# include("sources/ocws-sysmon.source")  # needs beta16 syntax fix

# --- User Overlay Config ---
include("user.config")
