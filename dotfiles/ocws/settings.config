#Api2
# settings.config — Exposed settings for SFWBar modes
# This file exposes all configurable options for easy customization
#
# USAGE:
#   1. Copy this file to ~/.config/ocws/settings.config
#   2. Edit the settings you want to change
#   3. The mode configs will use these values
#
# NOTE: This file is NOT overwritten by install.sh

# ============================================================
# Bar Settings
# ============================================================

# --- Top Bar ---
Set OCWS_TOP_BAR_SIZE = "32"
Set OCWS_TOP_BAR_EDGE = "top"
Set OCWS_TOP_BAR_LAYER = "top"

# --- Bottom Bar ---
Set OCWS_BOTTOM_BAR_SIZE = "40"
Set OCWS_BOTTOM_BAR_EDGE = "bottom"
Set OCWS_BOTTOM_BAR_LAYER = "top"

# --- Status Bar (single bar mode) ---
Set OCWS_STATUS_BAR_SIZE = "34"
Set OCWS_STATUS_BAR_EDGE = "top"
Set OCWS_STATUS_BAR_LAYER = "top"

# ============================================================
# Widget Settings
# ============================================================

# --- Launcher ---
Set OCWS_LAUNCHER_COMMAND = "rofi -show drun"
Set OCWS_LAUNCHER_LABEL = "  Apps"

# --- Clock ---
Set OCWS_CLOCK_FORMAT = "%H:%M"
Set OCWS_CLOCK_TOOLTIP_FORMAT = "%k:%M\n%x"

# --- Taskbar ---
Set OCWS_TASKBAR_ICONS = "true"
Set OCWS_TASKBAR_LABELS = "false"
Set OCWS_TASKBAR_TOOLTIPS = "true"
Set OCWS_TASKBAR_ICON_SIZE = "28"

# --- Dock ---
Set OCWS_DOCK_APPS = "chromium-browser,nautilus,kate,foot,rofi"

# ============================================================
# Visual Settings
# ============================================================

# --- Transparency ---
Set OCWS_BG_ALPHA = "0.92"
Set OCWS_BOTTOM_BAR_ALPHA = "0.88"
Set OCWS_POPUP_ALPHA = "0.95"

# --- Shadows ---
Set OCWS_SHADOW_ENABLED = "true"
Set OCWS_SHADOW_COLOR = "rgba(0, 0, 0, 0.4)"

# --- Borders ---
Set OCWS_BORDER_ENABLED = "true"
Set OCWS_BORDER_COLOR = "alpha(@ocws_fg, 0.1)"
Set OCWS_BORDER_RADIUS = "0"

# --- Transitions ---
Set OCWS_TRANSITION_ENABLED = "true"
Set OCWS_TRANSITION_DURATION = "0.15s"
Set OCWS_TRANSITION_EASING = "ease-out"

# ============================================================
# Feature Toggles
# ============================================================

# --- Enable/Disable features ---
Set OCWS_FEATURE_DOCK = "true"
Set OCWS_FEATURE_TASKBAR = "true"
Set OCWS_FEATURE_DESKTOP_WIDGETS = "true"
Set OCWS_FEATURE_NOTIFICATIONS = "true"
Set OCWS_FEATURE_TRAY = "true"

# --- Mode selection ---
# Options: doublepanel, crystaldock, minimal
Set OCWS_DEFAULT_MODE = "doublepanel"
