#Api2
# modes/topbar.config — Top status bar configuration
# Includes: launcher, workspaces, system metrics, clock, tray

bar "topbar:top" {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = $OCWSTopSize

  # --- Left: Launcher + Workspaces ---
  widget "launcher"
  widget "workspaces"

  # --- Center: Spacer ---
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: System Metrics + Status ---
  include("widget-sets/full.set")
}
