#Api2
# modes/css-bars.config — Bar-specific CSS styles

#CSS

/* ============================================================
 * Top Bar — glassmorphism panel
 * ============================================================ */
window#topbar {
  background-color: @shell_bg;
  border-radius: 0px;
  margin: 0px;
  border: none;
  box-shadow: 0 2px 12px @shadow;
  min-height: 32px;
}

/* ============================================================
 * Bottom Bar — dock-like glassmorphism panel
 * ============================================================ */
window#bottombar {
  background-color: alpha(@ocws_bg, 0.88);
  border-radius: 0px;
  margin: 0px;
  border: none;
  box-shadow: 0 -2px 16px @shadow;
  min-height: 40px;
  border-top: 1px solid alpha(@ocws_fg, 0.08);
}

/* ============================================================
 * Status Bar (single bar mode)
 * ============================================================ */
window#statusbar {
  background-color: @shell_bg;
  border-radius: 0px;
  margin: 0px;
  border: none;
  box-shadow: 0 2px 12px @shadow;
  min-height: 34px;
}

/* Bar grids */
grid#topbar, grid#bottombar, grid#statusbar {
  background-color: transparent;
  border: none;
  margin: 0px;
  padding: 0px 8px;
}
