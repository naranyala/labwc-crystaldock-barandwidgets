#Api2
# minimal.mode — Minimal status bar (clock, volume, battery, tray)
# Launch: sfwbar -f modes/minimal.mode

switcher { disable = true }

# --- Common Infrastructure ---
include("../ocws.config")

# --- Minimal Bar ---
bar {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = 28

  include("../widget-sets/minimal.set")
}
