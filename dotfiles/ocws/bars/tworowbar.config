#Api2
# bars/tworowbar.config — Bottom two-row taskbar
# Used by: tworow mode

bar "tworowbar:bottom" {
  edge = "bottom"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = 64

  # --- Left: Dock Apps ---
  widget "widgets/core/dock.widget"

  # --- Center: Taskbar (2 rows) ---
  taskbar {
    style = "taskbar"
    rows = 2
    icons = true
    labels = false
    tooltips = true
    icon_size = 28
    sort = false
    title_width = 20
    action[Drag] = Focus()
    action[RightClick] = Menu("winops")
    action[MiddleClick] = Close()
    css = "* { -GtkWidget-hexpand: true; -GtkWidget-halign: center; }"
  }

  # --- Spacer ---
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: Show Desktop ---
  widget "widgets/core/showdesktop.widget"
}
