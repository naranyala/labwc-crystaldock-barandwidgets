#Api2
# bars/dockbar.config — Bottom dock/taskbar
# Used by: dual mode

bar "dockbar:bottom" {
  edge = "bottom"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = $OCWS_BOTTOM_SIZE

  # --- Left: Dock Apps (inline) ---
  widget "widgets/core/dock.widget"

  # --- Center: Taskbar ---
  taskbar {
    style = "taskbar"
    rows = 1
    icons = true
    labels = false
    tooltips = true
    icon_size = 28
    sort = false
    title_width = 20
    action[Drag] = Focus()
    action[RightClick] = Menu("winops")
    action[MiddleClick] = Close()
    css = "* { -GtkWidget-hexpand: true; -GtkWidget-halign: center; }"
  }

  # --- Spacer ---
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: Show Desktop ---
  widget "widgets/core/showdesktop.widget"
}
