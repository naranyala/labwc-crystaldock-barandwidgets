#Api2

# Workspaces widget — inline dot pager on the bar
# Active dot is a filled pill (accent), occupied dots brighter,
# empty dots dim. Click a dot to switch, scroll to cycle.
export pager "workspaces" {
  style = "pager"
  pins = "1","2","3","4"
  preview = false
  action[ScrollUp] = WorkspaceUp()
  action[ScrollDown] = WorkspaceDown()
}

